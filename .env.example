NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
# Same OAuth Web Client ID as backend GOOGLE_CLIENT_ID (Google Cloud → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Enable Maps JavaScript API + Places API (New) on this key.
# Application restriction: HTTP referrers — add at least:
#   http://localhost:3001/*
#   https://gzura.com/*
#   https://www.gzura.com/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAP_ID=your-google-map-id